# Copy to .env and fill in. Every variable the app reads MUST be listed here
# (the smoke workflow boots from this file — drift breaks CI, which is the point).
# Real values live in .env locally and in the secret store (Azure Key Vault /
# GitHub secrets) when deployed. NEVER paste real values into chat, code, or commits.

# ── Database (component-based; code URL-encodes the password) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB={{project}}_db
POSTGRES_USER={{project}}
POSTGRES_PASSWORD=changeme

# ── App ──
APP_ENV=local            # local | staging | production
API_PORT=8000            # keep ports unique across projects on the shared Mac mini
WEB_PORT=3000

# ── LLM ──
LLM_API_BASE=https://api.ilmu.ai/v1
LLM_API_KEY=changeme
LLM_MODEL_FAST={{e.g. nemo-nano}}
LLM_MODEL_SMART={{e.g. nemo-super}}

# ── Object storage / misc ──
# AZURE_STORAGE_CONNECTION_STRING=changeme
