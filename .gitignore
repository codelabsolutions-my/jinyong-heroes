node_modules/
.venv/
venv/
__pycache__/
*.pyc

# ── Build output ──
.next/
out/
dist/
build/
*.tsbuildinfo
.turbo/

# ── Tooling caches ──
.ruff_cache/
.pytest_cache/
.mypy_cache/
coverage/
.coverage

# ── OS / editor ──
.DS_Store
.vscode/
.idea/

