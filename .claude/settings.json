{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git worktree list:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(ruff:*)",
      "Bash(pytest:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm turbo test:*)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(pre-commit run:*)",
      "Bash(gitleaks:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/docs-guard.sh"
          }
        ]
      }
    ]
  }
}
